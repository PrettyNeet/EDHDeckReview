# ── AI Provider ───────────────────────────────────────────────────────────────
# auto = try Anthropic, then OpenAI, then Ollama, then fall back to rule-based
AI_PROVIDER=auto

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Ollama (local) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Invite Auth / Supabase ────────────────────────────────────────────────────
# Leave false for local-only development without Supabase.
# Set true in Vercel after adding the Supabase values below.
INVITE_AUTH_ENABLED=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...
